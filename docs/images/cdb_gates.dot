digraph "common_data_bus" {
label="common_data_bus";
rankdir="LR";
remincross=true;
n1 [ shape=octagon, label="cdb_data", color="black", fontcolor="black" ];
n2 [ shape=octagon, label="cdb_tag", color="black", fontcolor="black" ];
n3 [ shape=octagon, label="cdb_valid", color="black", fontcolor="black" ];
n4 [ shape=octagon, label="fu0_data", color="black", fontcolor="black" ];
n5 [ shape=octagon, label="fu0_tag", color="black", fontcolor="black" ];
n6 [ shape=octagon, label="fu0_valid", color="black", fontcolor="black" ];
x0 [shape=box, style=rounded, label="BUF", ];
x1 [shape=box, style=rounded, label="BUF", ];
x2 [shape=box, style=rounded, label="BUF", ];
x0:e -> n1:w [color="black", fontcolor="black", style="setlinewidth(3)", label=""];
x1:e -> n2:w [color="black", fontcolor="black", style="setlinewidth(3)", label=""];
x2:e -> n3:w [color="black", fontcolor="black", label=""];
n4:e -> x0:w [color="black", fontcolor="black", style="setlinewidth(3)", label=""];
n5:e -> x1:w [color="black", fontcolor="black", style="setlinewidth(3)", label=""];
n6:e -> x2:w [color="black", fontcolor="black", label=""];
}
